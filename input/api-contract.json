{
  "openapi": "3.0.0",
  "info": {
    "title": "Shopping Cart API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/cart": {
      "get": {
        "summary": "Get current user cart",
        "responses": {
          "200": {
            "description": "Cart retrieved successfully",
            "content": {
              "application/json": {
                "example": {
                  "cartId": "cart_abc123",
                  "userId": "usr_001",
                  "items": [
                    {
                      "productId": "prod_001",
                      "name": "Wireless Headphones",
                      "price": 1299,
                      "quantity": 2,
                      "inStock": true,
                      "imageUrl": "/images/headphones.jpg"
                    }
                  ],
                  "subtotal": 2598,
                  "discountCode": null,
                  "discountAmount": 0,
                  "total": 2598,
                  "freeShipping": true,
                  "itemCount": 2
                }
              }
            }
          },
          "401": { "description": "Unauthorised — guest user" }
        }
      }
    },
    "/api/cart/items": {
      "post": {
        "summary": "Add item to cart",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["productId", "quantity"],
                "properties": {
                  "productId": { "type": "string", "example": "prod_001" },
                  "quantity": { "type": "integer", "minimum": 1, "maximum": 99, "example": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Item added successfully" },
          "400": { "description": "Invalid quantity or product ID" },
          "409": { "description": "Cart full — maximum 10 unique items reached" },
          "422": { "description": "Product is out of stock" },
          "401": { "description": "Unauthorised" }
        }
      }
    },
    "/api/cart/items/{productId}": {
      "patch": {
        "summary": "Update item quantity",
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["quantity"],
                "properties": {
                  "quantity": { "type": "integer", "minimum": 1, "maximum": 99 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Quantity updated" },
          "400": { "description": "Invalid quantity — must be between 1 and 99" },
          "404": { "description": "Item not found in cart" }
        }
      },
      "delete": {
        "summary": "Remove item from cart",
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Item removed — returns updated cart" },
          "404": { "description": "Item not found in cart" }
        }
      }
    },
    "/api/cart/discount": {
      "post": {
        "summary": "Apply discount code",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["code"],
                "properties": {
                  "code": { "type": "string", "example": "SAVE10" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Discount applied",
            "content": {
              "application/json": {
                "example": {
                  "code": "SAVE10",
                  "discountType": "percentage",
                  "discountValue": 10,
                  "discountAmount": 259.8,
                  "newTotal": 2338.2
                }
              }
            }
          },
          "400": { "description": "Invalid or expired discount code" },
          "409": { "description": "A discount code is already applied — remove it first" }
        }
      },
      "delete": {
        "summary": "Remove applied discount code",
        "responses": {
          "200": { "description": "Discount removed — original total restored" }
        }
      }
    },
    "/api/cart/checkout": {
      "post": {
        "summary": "Initiate checkout from cart",
        "responses": {
          "200": {
            "description": "Checkout session created",
            "content": {
              "application/json": {
                "example": {
                  "checkoutSessionId": "chk_xyz789",
                  "redirectUrl": "/checkout/chk_xyz789"
                }
              }
            }
          },
          "400": { "description": "Cart is empty" },
          "401": { "description": "Must be logged in to checkout" },
          "422": { "description": "One or more items went out of stock" }
        }
      }
    }
  }
}